MONGO_URI=mongodb://localhost:27017

# ENV controls the default DB name (can be overridden by MONGO_DB):
#   dev  → waib_carrefour_traiteur_dev_db
#   prod → waib_carrefour_traiteur_db
ENV=dev

# Override the DB name directly (optional — takes priority over ENV)
# MONGO_DB=waib_carrefour_traiteur_dev_db

# Logging level: DEBUG | INFO | WARNING | ERROR  (default: INFO)
LOG_LEVEL=INFO

# Logging format: console | json
# console → pretty coloured output for local dev / Python terminal
# json    → newline-delimited JSON for K8s / Docker / log aggregators
# (default: auto-detect — json if no TTY, console otherwise)
LOG_FORMAT=console

# ── OpenAI embeddings ─────────────────────────────────────────────────────────
# Required when running --pinecone.  Used to call text-embedding-3-large.
OPENAI_API_KEY=sk-...

# Embedding model to use (default: text-embedding-3-large)
# EMBEDDING_MODEL=text-embedding-3-large

# ── Pinecone vector store ─────────────────────────────────────────────────────
# Required when running --pinecone.
PINECONE_API_KEY=pcsk_...

# Target index name (default: waib-dev-large)
# PINECONE_INDEX_NAME=waib-dev-large
